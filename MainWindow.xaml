<Window x:Class="PasswordGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Password Generator"
        Height="440"
        Width="620"
        Icon="Assets/padlock.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0"
                   Source="Assets/padlock.png"
                   Width="42"
                   Height="42"
                   Margin="0,0,12,0"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <TextBlock Grid.Column="1"
                       Text="Password Generator"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="2"
                    Content="About"
                    Width="70"
                    Height="28"
                    VerticalAlignment="Center"
                    Click="About_Click"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Length"
                       FontSize="16"
                       VerticalAlignment="Center"/>

            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="28"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="LengthBox"
                         Grid.Column="0"
                         FontSize="18"
                         TextAlignment="Center"
                         VerticalContentAlignment="Center"
                         Height="36"/>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
                            Content="▲"
                            FontSize="10"
                            Click="LengthUp_Click"/>

                    <Button Grid.Row="1"
                            Content="▼"
                            FontSize="10"
                            Click="LengthDown_Click"/>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="PasswordBox"
                     Grid.Column="0"
                     Margin="0,0,10,0"
                     FontSize="16"
                     VerticalContentAlignment="Center"
                     IsReadOnly="True"
                     Height="36"/>

            <Button Grid.Column="1"
                    Content="Copy"
                    Click="Copy_Click"
                    Height="36"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <CheckBox x:Name="UpperBox"
                          Content="Letters  A-Z"
                          FontSize="16"
                          Margin="0,6"/>

                <CheckBox x:Name="LowerBox"
                          Content="Letters  a-z"
                          FontSize="16"
                          Margin="0,12,0,6"/>

                <CheckBox x:Name="DigitBox"
                          Content="Digits  0-9"
                          FontSize="16"
                          Margin="0,12,0,6"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Grid Margin="0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox x:Name="SymbolBox"
                              Grid.Column="0"
                              Content="Characters"
                              FontSize="16"
                              VerticalAlignment="Center"/>

                    <TextBox x:Name="SymbolTextBox"
                             Grid.Column="1"
                             FontSize="16"
                             Height="32"
                             VerticalContentAlignment="Center"/>
                </Grid>

                <Grid Margin="0,12,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox x:Name="ExcludeBox"
                              Grid.Column="0"
                              Content="Exclude"
                              FontSize="16"
                              VerticalAlignment="Center"/>

                    <TextBox x:Name="ExcludeTextBox"
                             Grid.Column="1"
                             FontSize="16"
                             Height="32"
                             VerticalContentAlignment="Center"/>
                </Grid>

                <CheckBox x:Name="NoNumberOrSymbolEndsBox"
                          Content="No number or symbol at start/end"
                          FontSize="16"
                          Margin="0,14,0,6"/>
            </StackPanel>
        </Grid>

        <Button Grid.Row="4"
                Content="Generate and Copy"
                Height="42"
                FontSize="16"
                FontWeight="Bold"
                Click="Generate_Click"/>
    </Grid>
</Window>
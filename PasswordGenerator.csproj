<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <StartupObject>PasswordGenerator.App</StartupObject>
    <ApplicationIcon>Assets\padlock.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Assets\LOGOLLCTransparentBG.png" />
    <None Remove="Assets\LOGOLLCTransparentBGCROP.png" />
    <None Remove="Assets\padlock.png" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\padlock.ico" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\LOGOLLCTransparentBG.png" />
    <Resource Include="Assets\LOGOLLCTransparentBGCROP.png" />
    <Resource Include="Assets\padlock.png" />
  </ItemGroup>

  <ItemGroup>
    <None Update="Assets\padlock.ico">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>

<Window x:Class="PasswordGenerator.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        Height="520"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">

        <StackPanel VerticalAlignment="Center">

            <Image Source="Assets/padlock.png"
                   Height="82"
                   Stretch="Uniform"
                   Margin="0,0,0,10"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <TextBlock Text="Password Generator"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <TextBlock Text="Version 1.0.0"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Foreground="DimGray"
                       Margin="0,0,0,18"/>

            <TextBlock TextWrapping="Wrap"
                       FontSize="14"
                       TextAlignment="Center"
                       MaxWidth="420"
                       Margin="0,0,0,20">

This software is provided as-is without warranty of any kind.

Use at your own risk.

ERPCreations LLC assumes no liability for damages,
loss of data, security issues, or misuse resulting
from the use of this software.

            </TextBlock>

            <Image Source="Assets/LOGOLLCTransparentBGCROP.png"
                   Height="58"
                   Stretch="Uniform"
                   Margin="0,0,0,18"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <TextBlock FontSize="14"
                       TextAlignment="Center"
                       Margin="0,0,0,18">

                © ERPCreations LLC
                <LineBreak/>
                Open source under the MIT License

            </TextBlock>

            <Button Content="OK"
                    Width="90"
                    Height="32"
                    HorizontalAlignment="Center"
                    Click="Ok_Click"/>

        </StackPanel>

    </Grid>
</Window>